#!/usr/bin/env bash

set -euo pipefail

REPO_ROOT="${REPO_ROOT:-/Users/juan/src/github.com/aboveproperty/aboveproperty.devops}"
PYTHON_SCRIPT="${PYTHON_SCRIPT:-${REPO_ROOT}/scripts/solr9_reindex_manifest_gbq_to_s3.py}"
SQL_DIR="${SQL_DIR:-${REPO_ROOT}/scripts/solr9-reindex-manifest-queries}"

DEFAULT_BUCKET="${S3_BUCKET:-solr9-ids-for-indexing}"
DEFAULT_COLLECTION="${COLLECTION:-agreements}"
DEFAULT_ENVIRONMENT="${ENVIRONMENT:-dev}"
DEFAULT_PROJECT="${GCP_PROJECT:-abvprp-stage}"

TEMP_SQL_FILE=""

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
GREY='\033[0;90m'
BOLD='\033[1m'
RESET='\033[0m'

cleanup() {
  if [[ -n "${TEMP_SQL_FILE:-}" && -f "$TEMP_SQL_FILE" ]]; then
    rm -f "$TEMP_SQL_FILE"
  fi
}

trap cleanup EXIT

print_help() {
  local text="$1"

  if [[ -n "$text" ]]; then
    echo -e "${GREY}  ${text}${RESET}" >&2
  fi
}

print_valid_values() {
  echo -e "${GREY}  Valid values: $*${RESET}" >&2
}

prompt_value() {
  local prompt="$1"
  local default="$2"
  local help_text="${3:-}"
  local value

  print_help "$help_text"
  read -r -p "$prompt [$default]: " value
  echo "${value:-$default}"
}

prompt_optional_value() {
  local prompt="$1"
  local help_text="${2:-}"
  local value

  print_help "$help_text"
  read -r -p "$prompt [optional]: " value
  echo "$value"
}

prompt_valid_value() {
  local prompt="$1"
  local default="$2"
  local help_text="$3"
  shift 3
  local valid_values=("$@")
  local value

  while true; do
    print_help "$help_text"
    print_valid_values "${valid_values[@]}"

    read -r -p "$prompt [$default]: " value
    value=${value:-$default}

    for valid in "${valid_values[@]}"; do
      if [[ "$value" == "$valid" ]]; then
        echo "$value"
        return 0
      fi
    done

    echo -e "${RED}❌ Invalid value. Valid values are: ${valid_values[*]}${RESET}" >&2
  done
}

prompt_yes_no() {
  local prompt="$1"
  local default="$2"
  local help_text="${3:-}"
  local value

  while true; do
    print_help "$help_text"
    echo -e "${GREY}  Valid values: yes no${RESET}" >&2

    read -r -p "$prompt [$default]: " value
    value=${value:-$default}

    case "$value" in
      y|yes|Y|YES)
        echo "yes"
        return 0
        ;;
      n|no|N|NO)
        echo "no"
        return 0
        ;;
      *)
        echo -e "${RED}❌ Invalid value. Use yes or no.${RESET}" >&2
        ;;
    esac
  done
}

human_size() {
  local bytes="$1"

  awk -v bytes="$bytes" '
    function human(x) {
      split("B KB MB GB TB", units, " ")
      i = 1
      while (x >= 1024 && i < 5) {
        x = x / 1024
        i++
      }
      return sprintf("%.2f %s", x, units[i])
    }
    BEGIN {
      print human(bytes)
    }
  '
}

file_size_bytes() {
  local file="$1"

  if stat -f "%z" "$file" >/dev/null 2>&1; then
    stat -f "%z" "$file"
  else
    stat -c "%s" "$file"
  fi
}

file_modified_date() {
  local file="$1"

  if stat -f "%Sm" -t "%Y-%m-%d %H:%M:%S" "$file" >/dev/null 2>&1; then
    stat -f "%Sm" -t "%Y-%m-%d %H:%M:%S" "$file"
  else
    stat -c "%y" "$file" | cut -d'.' -f1
  fi
}

default_manifest_id_key_for_collection() {
  local collection="$1"

  case "$collection" in
    agreements)
      echo "agreementId"
      ;;
    customers)
      echo "customerId"
      ;;
    products)
      echo "productId"
      ;;
    reservations)
      echo "reservationId"
      ;;
    reservationproducts)
      echo "reservationProductId"
      ;;
    *)
      echo "documentId"
      ;;
  esac
}

default_source_for_collection() {
  local project="$1"
  local collection="$2"

  case "$collection" in
    agreements)
      echo "gbq:${project}.ROOT.agreements_latest_v3"
      ;;
    customers)
      echo "gbq:${project}.ABVPRP.customers_latest_v3"
      ;;
    *)
      echo ""
      ;;
  esac
}

pick_sql_file() {
  local sql_files=()
  local index
  local sql_file
  local file_name
  local modified
  local size_bytes
  local display_size
  local sql_pick

  while IFS= read -r file; do
    sql_files+=("$file")
  done < <(find "$SQL_DIR" -maxdepth 1 -type f -name "*.sql" | sort)

  if [[ "${#sql_files[@]}" -eq 0 ]]; then
    echo -e "${RED}❌ No .sql files found in:${RESET}" >&2
    echo "$SQL_DIR" >&2
    exit 1
  fi

  echo >&2
  echo -e "${CYAN}📄 Available SQL files${RESET}" >&2
  echo -e "${GREY}  Directory: $SQL_DIR${RESET}" >&2
  echo >&2

  echo -e "${GREY}$(printf '%-5s %-20s %-12s %s' "NUM" "MODIFIED" "SIZE" "SQL FILE")${RESET}" >&2
  echo -e "${GREY}$(printf '%-5s %-20s %-12s %s' "---" "--------" "----" "--------")${RESET}" >&2

  index=1

  for sql_file in "${sql_files[@]}"; do
    file_name="$(basename "$sql_file")"
    modified="$(file_modified_date "$sql_file")"
    size_bytes="$(file_size_bytes "$sql_file")"
    display_size="$(human_size "$size_bytes")"

    echo -e "${GREY}$(printf '%-5s %-20s %-12s %s' "$index" "$modified" "$display_size" "$file_name")${RESET}" >&2

    index=$((index + 1))
  done

  echo >&2

  while true; do
    print_help "Pick the SQL file number to use as --query-file."
    read -r -p "Pick SQL file number [1-${#sql_files[@]}]: " sql_pick

    if [[ "$sql_pick" =~ ^[0-9]+$ ]] && \
       [[ "$sql_pick" -ge 1 ]] && \
       [[ "$sql_pick" -le "${#sql_files[@]}" ]]; then
      echo "${sql_files[$((sql_pick - 1))]}"
      return 0
    fi

    echo -e "${RED}❌ Invalid selection. Enter a number between 1 and ${#sql_files[@]}.${RESET}" >&2
  done
}

paste_sql_file() {
  TEMP_SQL_FILE=$(mktemp "/tmp/solr9-reindex-query-XXXXXX.sql")

  echo >&2
  echo -e "${YELLOW}📝 Paste your SQL below.${RESET}" >&2
  echo -e "${GREY}  Finish by typing EOF on its own line, then press ENTER.${RESET}" >&2
  echo >&2

  while IFS= read -r line; do
    if [[ "$line" == "EOF" ]]; then
      break
    fi

    echo "$line" >> "$TEMP_SQL_FILE"
  done

  if [[ ! -s "$TEMP_SQL_FILE" ]]; then
    echo -e "${RED}❌ SQL content is empty.${RESET}" >&2
    exit 1
  fi

  echo "$TEMP_SQL_FILE"
}

if [[ ! -f "$PYTHON_SCRIPT" ]]; then
  echo -e "${RED}❌ Python script not found:${RESET}"
  echo "$PYTHON_SCRIPT"
  exit 1
fi

if [[ ! -d "$SQL_DIR" ]]; then
  echo -e "${RED}❌ SQL directory not found:${RESET}"
  echo "$SQL_DIR"
  exit 1
fi

echo
echo -e "${BOLD}${CYAN}🪣 GBQ → S3 Solr9 Reindex Manifest Generator${RESET}"
echo -e "${GREY}  Script: $PYTHON_SCRIPT${RESET}"
echo -e "${GREY}  SQL Dir: $SQL_DIR${RESET}"
echo

CREDENTIALS=$(prompt_optional_value \
  "Enter GBQ credentials JSON path" \
  "Optional. Leave empty to use Application Default Credentials from gcloud auth application-default login or existing GOOGLE_APPLICATION_CREDENTIALS.")

if [[ -n "$CREDENTIALS" ]]; then
  export GOOGLE_APPLICATION_CREDENTIALS="$CREDENTIALS"
fi

PROJECT=$(prompt_valid_value \
  "Enter GCP project" \
  "$DEFAULT_PROJECT" \
  "Google Cloud project used by the BigQuery client." \
  abvprp-stage abvprp-prod)

BUCKET=$(prompt_value \
  "Enter S3 bucket" \
  "$DEFAULT_BUCKET" \
  "Bucket used for manifest upload. Can also be provided through S3_BUCKET.")

COLLECTION=$(prompt_value \
  "Enter collection" \
  "$DEFAULT_COLLECTION" \
  "Collection name used in S3 path and manifest filename. Examples: agreements, customers, products, reservations.")

ENVIRONMENT=$(prompt_valid_value \
  "Enter environment" \
  "$DEFAULT_ENVIRONMENT" \
  "Path segment for S3 output: s3://bucket/collection/environment/input/... Can also be provided through ENVIRONMENT." \
  dev stage prod)

SQL_SOURCE=$(prompt_valid_value \
  "Choose SQL source" \
  "file" \
  "Use file to pick from the repository SQL directory, or paste to enter SQL manually." \
  file paste)

if [[ "$SQL_SOURCE" == "file" ]]; then
  QUERY_FILE=$(pick_sql_file)
else
  QUERY_FILE=$(paste_sql_file)
fi

MANIFEST_TYPE=$(prompt_value \
  "Enter manifest type" \
  "reindex_ids" \
  "Second segment in manifest filename, for example agreements_reindex_ids_TIMESTAMP.jsonl.")

MANIFEST_ID_KEY_DEFAULT=$(default_manifest_id_key_for_collection "$COLLECTION")
MANIFEST_ID_KEY=$(prompt_value \
  "Enter manifest ID key" \
  "$MANIFEST_ID_KEY_DEFAULT" \
  "JSONL key written for each ID. Example for agreements: agreementId. Example for customers: customerId.")

MANIFEST_VALUE_VALIDATION=$(prompt_valid_value \
  "Enter manifest value validation" \
  "uuid" \
  "Validation applied to each manifest ID value before writing JSONL. Use none to skip validation." \
  uuid none)

SOURCE_DEFAULT=$(default_source_for_collection "$PROJECT" "$COLLECTION")
if [[ -n "$SOURCE_DEFAULT" ]]; then
  SOURCE=$(prompt_value \
    "Enter source metadata" \
    "$SOURCE_DEFAULT" \
    "Optional lineage metadata written to each JSONL row.")
else
  SOURCE=$(prompt_optional_value \
    "Enter source metadata" \
    "Optional lineage metadata. Example: gbq:${PROJECT}.DATASET.TABLE")
fi

REASON=$(prompt_value \
  "Enter reason metadata" \
  "full-${COLLECTION}-reindex" \
  "Reason written to each JSONL row, for example full-agreements-reindex or repair-missing-ids.")

DRY_RUN=$(prompt_yes_no \
  "Dry run?" \
  "no" \
  "yes writes JSONL to stdout only and does not upload to S3. no uploads to S3.")

S3_ENDPOINT_URL=$(prompt_optional_value \
  "Enter S3 endpoint URL" \
  "Optional. Use for LocalStack or custom S3 endpoint. Leave empty for normal AWS S3.")

CMD=(
  python3 "$PYTHON_SCRIPT"
  --project "$PROJECT"
  --query-file "$QUERY_FILE"
  --bucket "$BUCKET"
  --collection "$COLLECTION"
  --environment "$ENVIRONMENT"
  --manifest-type "$MANIFEST_TYPE"
  --manifest-id-key "$MANIFEST_ID_KEY"
)

if [[ "$MANIFEST_VALUE_VALIDATION" != "none" ]]; then
  CMD+=(--manifest-value-validation "$MANIFEST_VALUE_VALIDATION")
fi

if [[ -n "$SOURCE" ]]; then
  CMD+=(--source "$SOURCE")
fi

CMD+=(--reason "$REASON")

if [[ "$DRY_RUN" == "yes" ]]; then
  CMD+=(--dry-run)
fi

if [[ -n "$S3_ENDPOINT_URL" ]]; then
  CMD+=(--s3-endpoint-url "$S3_ENDPOINT_URL")
fi

TARGET_S3_PREFIX="s3://${BUCKET}/${COLLECTION}/${ENVIRONMENT}/input/"
TARGET_FILE_PATTERN="${COLLECTION}_${MANIFEST_TYPE}_<UTC_TIMESTAMP>.jsonl"

echo
echo -e "${BOLD}${GREEN}🚀 Running GBQ → S3 manifest generator${RESET}"
echo "Project:                    $PROJECT"
echo "Query File:                 $QUERY_FILE"
echo "Bucket:                     $BUCKET"
echo "Collection:                 $COLLECTION"
echo "Environment:                $ENVIRONMENT"
echo "Manifest Type:              $MANIFEST_TYPE"
echo "Manifest ID Key:            $MANIFEST_ID_KEY"
echo "Manifest Value Validation:  $MANIFEST_VALUE_VALIDATION"
echo "Source:                     ${SOURCE:-<none>}"
echo "Reason:                     $REASON"
echo "Dry Run:                    $DRY_RUN"
echo "S3 Endpoint URL:            ${S3_ENDPOINT_URL:-<none>}"
echo "Target Prefix:              $TARGET_S3_PREFIX"
echo "Target Pattern:             $TARGET_FILE_PATTERN"
echo

echo -e "${GREY}Command:${RESET}"
printf ' %q' "${CMD[@]}"
echo
echo

"${CMD[@]}"

#!/usr/bin/env bash

set -euo pipefail

FUNCTION_NAME="solr9-reindex-s3-trigger"
JOB_QUEUE="solr9-reindex-job-queue"
MANIFEST_BUCKET_NAME="solr9-ids-for-indexing"

# Runtime connection/auth values are intentionally NOT stored in Lambda env vars.
# BASE_URL, ADMIN_USERNAME, and ADMIN_PASSWORD are injected into the AWS Batch
# container from the Batch job definition `secrets` block backed by AWS Secrets Manager.
# Keeping them out of Lambda avoids exposing secrets in Lambda configuration,
# CLI history, copied terminal output, or accidental Lambda container overrides.
LAMBDA_FORBIDDEN_ENV_KEYS=(
  BASE_URL
  ADMIN_USERNAME
  ADMIN_PASSWORD
)

TEMP_ENV_FILE=""

cleanup() {
  if [[ -n "${TEMP_ENV_FILE:-}" && -f "$TEMP_ENV_FILE" ]]; then
    rm -f "$TEMP_ENV_FILE"
  fi
}

trap cleanup EXIT

prompt_value() {
  local prompt="$1"
  local default="$2"
  local value

  read -r -p "$prompt [$default]: " value
  echo "${value:-$default}"
}

prompt_required_value() {
  local prompt="$1"
  local default="$2"
  local value

  while true; do
    value=$(prompt_value "$prompt" "$default")

    if [[ -n "$value" && "$value" != "null" ]]; then
      echo "$value"
      return 0
    fi

    echo "❌ Value is required." >&2
  done
}

prompt_valid_value() {
  local prompt="$1"
  local default="$2"
  shift 2
  local valid_values=("$@")
  local value

  while true; do
    value=$(prompt_value "$prompt" "$default")

    for valid in "${valid_values[@]}"; do
      if [[ "$value" == "$valid" ]]; then
        echo "$value"
        return 0
      fi
    done

    echo "❌ Invalid value. Valid values are: ${valid_values[*]}" >&2
  done
}

prompt_positive_int() {
  local prompt="$1"
  local default="$2"
  local value

  while true; do
    value=$(prompt_value "$prompt" "$default")

    if [[ "$value" =~ ^[0-9]+$ ]] && [[ "$value" -gt 0 ]]; then
      echo "$value"
      return 0
    fi

    echo "❌ Invalid value. Please enter a positive number." >&2
  done
}

# read -r -p "Enter AWS region [us-east-1]: " REGION
REGION=${REGION:-us-east-1}

echo
echo "🔎 Reading current Lambda environment first"
echo "Region:   $REGION"
echo "Function: $FUNCTION_NAME"
echo

CURRENT_CONFIG=$(aws lambda get-function-configuration \
  --region "$REGION" \
  --function-name "$FUNCTION_NAME" \
  --output json)

CURRENT_ENV=$(echo "$CURRENT_CONFIG" | jq '.Environment.Variables // {}')

current_var() {
  local name="$1"
  echo "$CURRENT_ENV" | jq -r --arg name "$name" '.[$name] // empty'
}

CURRENT_JOB_DEFINITION=$(current_var "JOB_DEFINITION")
CURRENT_BATCH_SIZE=$(current_var "BATCH_SIZE")
CURRENT_CONTAINER_DRY_RUN=$(current_var "CONTAINER_DRY_RUN")
CURRENT_MAX_HTTP_RETRIES=$(current_var "MAX_HTTP_RETRIES")

echo "✅ Current values loaded"
echo

echo "🔐 Secret handling note:"
echo "BASE_URL, ADMIN_USERNAME, and ADMIN_PASSWORD must not be stored in Lambda env vars."
echo "They are provided to the AWS Batch container by the Batch job definition secrets block."
echo "This script will remove those keys from the Lambda environment if they already exist."
echo

echo "⚠️  Job Definition note:"
echo "If the Python runner image, command, or Batch secrets changed, create/register a new AWS Batch job definition revision first."
echo "Then enter the new revision here, for example: solr9-manifest-reindex:4"
echo

JOB_DEFINITION=$(prompt_required_value \
  "Enter JOB_DEFINITION" \
  "${CURRENT_JOB_DEFINITION:-solr9-manifest-reindex:4}")

BATCH_SIZE=$(prompt_positive_int \
  "Enter BATCH_SIZE" \
  "${CURRENT_BATCH_SIZE:-50}")

CONTAINER_DRY_RUN=$(prompt_valid_value \
  "Enter CONTAINER_DRY_RUN" \
  "${CURRENT_CONTAINER_DRY_RUN:-0}" \
  0 1)

MAX_HTTP_RETRIES=$(prompt_valid_value \
  "Enter MAX_HTTP_RETRIES" \
  "${CURRENT_MAX_HTTP_RETRIES:-0}" \
  0 1 2 3 4 5)

UPDATED_ENV=$(echo "$CURRENT_ENV" | jq \
  --arg JOB_QUEUE "$JOB_QUEUE" \
  --arg JOB_DEFINITION "$JOB_DEFINITION" \
  --arg BATCH_SIZE "$BATCH_SIZE" \
  --arg CONTAINER_DRY_RUN "$CONTAINER_DRY_RUN" \
  --arg MAX_HTTP_RETRIES "$MAX_HTTP_RETRIES" \
  --arg MANIFEST_BUCKET_NAME "$MANIFEST_BUCKET_NAME" \
  '
    del(.BASE_URL, .ADMIN_USERNAME, .ADMIN_PASSWORD)
    | .JOB_QUEUE = $JOB_QUEUE
    | .JOB_DEFINITION = $JOB_DEFINITION
    | .BATCH_SIZE = $BATCH_SIZE
    | .CONTAINER_DRY_RUN = $CONTAINER_DRY_RUN
    | .MAX_HTTP_RETRIES = $MAX_HTTP_RETRIES
    | .MANIFEST_BUCKET_NAME = $MANIFEST_BUCKET_NAME
  ')

TEMP_ENV_FILE=$(mktemp "/tmp/lambda-env-payload-XXXXXX.json")

jq -n \
  --argjson variables "$UPDATED_ENV" \
  '{Variables: $variables}' \
  > "$TEMP_ENV_FILE"

echo
echo "🚀 Updating Lambda environment"
echo "Region:               $REGION"
echo "Function:             $FUNCTION_NAME"
echo "JOB_QUEUE:            $JOB_QUEUE"
echo "JOB_DEFINITION:       $JOB_DEFINITION"
echo "BATCH_SIZE:           $BATCH_SIZE"
echo "CONTAINER_DRY_RUN:    $CONTAINER_DRY_RUN"
echo "MAX_HTTP_RETRIES:     $MAX_HTTP_RETRIES"
echo "MANIFEST_BUCKET_NAME: $MANIFEST_BUCKET_NAME"
echo "Forbidden Env Keys:   ${LAMBDA_FORBIDDEN_ENV_KEYS[*]}"
echo "Runtime Secrets:      AWS Batch job definition injects BASE_URL, ADMIN_USERNAME, ADMIN_PASSWORD"
echo "Payload File:         $TEMP_ENV_FILE"
echo

echo "Environment payload preview:"
jq '.' "$TEMP_ENV_FILE"
echo

aws lambda wait function-updated \
  --region "$REGION" \
  --function-name "$FUNCTION_NAME" || true

aws lambda update-function-configuration \
  --region "$REGION" \
  --function-name "$FUNCTION_NAME" \
  --environment "file://$TEMP_ENV_FILE" \
  --output table

echo
echo "⏳ Waiting for Lambda update to finish..."

aws lambda wait function-updated \
  --region "$REGION" \
  --function-name "$FUNCTION_NAME"

echo
echo "✅ Lambda environment updated"
echo

echo "🔎 Verified values"
echo "------------------------------------------------------------"

aws lambda get-function-configuration \
  --region "$REGION" \
  --function-name "$FUNCTION_NAME" \
  --query 'Environment.Variables' \
  --output json \
| jq '
    (. // {})
    | del(.BASE_URL, .ADMIN_USERNAME, .ADMIN_PASSWORD)
  '

echo
echo "🔎 Forbidden Lambda env var check"
echo "------------------------------------------------------------"

FORBIDDEN_PRESENT=$(aws lambda get-function-configuration \
  --region "$REGION" \
  --function-name "$FUNCTION_NAME" \
  --query 'Environment.Variables' \
  --output json \
| jq -r '
    (. // {})
    | ["BASE_URL", "ADMIN_USERNAME", "ADMIN_PASSWORD"] as $forbidden
    | [keys[]? | select(. as $key | $forbidden | index($key))]
    | .[]?
  ')

if [[ -n "$FORBIDDEN_PRESENT" ]]; then
  echo "❌ Forbidden Lambda env vars still present:"
  echo "$FORBIDDEN_PRESENT"
  exit 1
fi

echo "✅ BASE_URL, ADMIN_USERNAME, and ADMIN_PASSWORD are not present in Lambda env vars."

            "label": "🔥 1️⃣ PCC: Clone repos",
            "type": "shell",
            "command": "sh clone.sh",
            "presentation": {
                "panel": "new", // 🆕 this makes each run use a fresh terminal 
                "reveal": "always"
            },
            "options": {

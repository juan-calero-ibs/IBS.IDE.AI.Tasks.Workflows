        // if [[ ! -x "$CQLSH_BIN" ]]; then
        //   die "ERROR: cqlsh not found/executable at $CQLSH_BIN. Set CQLSH_BIN or install Cassandra client."
        // fi
        
        // run_cqlsh() {
        //   # Use pyenv version if available (matches your alias behavior)
        //   PYENV_VERSION="$CQLSH_PYENV_VERSION" "$CQLSH_BIN" --ssl "$@"
        // }
        // 2) Reemplaza esta línea:
        // cqlsh --ssl -k abvprp ${CASSANDRA_HOST} --request-timeout=300 --execute="${alter}"
        // por esta:
        // run_cqlsh -k abvprp "${CASSANDRA_HOST}" --request-timeout=300 --execute="${alter}"

        {
            "label": "🛢️ 🚀 Run RollForward (macOS/Linux)",
            "type": "shell",
            "command": "sh rollForward.sh -e ${input:env} -p $HTTP_ADMIN_PASSWORD -c $CASSANDRA_HOST -t $TARGET_HOST -l $LOAD_TOKEN -s $SOLR_HOST",
            "options": {
                // Path al repo aboveproperty.sql
                "cwd": "${env:HOME}/src/github.com/aboveproperty/aboveproperty.sql/cassandra/patches/${input:patchId}",
                "env": {
                    "CASSANDRA_HOST": "${input:cassandraHost}",
                    "TARGET_HOST": "${input:targetHost}",
                    "HTTP_ADMIN_PASSWORD": "${input:adminPassword}",
                    "LOAD_TOKEN": "${input:loadToken}",
                    "SOLR_HOST": "${input:solrHost}",
                    // 👇 Aquí viene la magia
                    "PATH": "/opt/abvprp/apache-cassandra/bin:${env:PATH}",
                    "PYENV_VERSION": "2.7.18"
                }
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            }
        },
        // --------------------- UMT / Bablefish 🐡 ---------------------
        {

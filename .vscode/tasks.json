                "echo": false,
                "reveal": "always",
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            }
        },
        {
            "label": "🔥 🛑 Stop Ember",
            "type": "shell",
            "command": "kill -9 $(lsof -t -i :4200) 2>/dev/null || true; kill -9 $(lsof -t -i :4201) 2>/dev/null || true; echo 'Ember stopped 🛑'",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "showReuseMessage": false,
                "clear": true
            }

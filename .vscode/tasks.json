            },
            "options": {
                "cwd": "${env:HOME}/src/github.com/aboveproperty/aboveproperty.ux-pcc-workspace/packages/aboveproperty.ux-pcc"
            },
            "isBackground": true,
            "problemMatcher": {
                "owner": "ember",
                "fileLocation": [
                    "relative",
                    "${env:HOME}/src/github.com/aboveproperty"
                ],
                "pattern": [
                    {
                        "regexp": "^(.*?): line (\\d+), col (\\d+), (Error|Warning): (.*)$",
                        "file": 1,
                        "line": 2,
                        "column": 3,
                        "severity": 4,
                        "message": 5
                    },
                    {
                        "regexp": "^Error: (.*)$",
                        "severity": 0,
                        "message": 1
                    },
                    {
                        "regexp": "^(.*?):(\\d+):(\\d+): (error|warning) (.*)$",
                        "file": 1,
                        "line": 2,
                        "column": 3,
                        "severity": 4,
                        "message": 5
                    }
                ]
            }
